<section class="">

  <h1 class="flex items-center mb-2 text-2xl font-bold sm:text-3xl xl:text-4xl">
    {{ page.settings.title }}
  </h1>

  <div>
    <div class="flex items-center space-x-2">
      {% if site.settings.is_allow_author %}
      <img src="{{ page.author.avatar_url | default: default_avatar_url }}" class="w-8 h-8 rounded-full" />
      {% endif %}
      <div>
        {% if site.settings.is_allow_author %}
        <p class="text-lead line-clamp-2 mb-[3px] text-heading-6">
          {{ page.author.name }}
        </p>
        {% endif %}
        {% if site.settings.is_allow_published_at %}
        <p class="text-sm text-md">{{ 'generic.published_at' | t }}：{{ page.published_at | date: "%Y-%m-%d" }}</p>
        {% endif %}
      </div>
    </div>
  </div>

  {% if page.settings.description %}
    <figure class="p-4 my-2 border-l-2 rounded-md border-primary">
      <blockquote class="font-semibold">
        <p>{{ page.settings.description }}</p>
      </blockquote>
    </figure>
  {% endif %}

  <div class="flow-root mt-8">
    <div class="overflow-auto">
      <div data-controller="view_images"
        class="ProseMirror break-words scroll-mt-96 scroll-pt-72">
        {{ page.settings.content }}
      </div>
    </div>
  </div>

  {% if page.settings.tags.size > 0 %}
    <div class="flex flex-wrap items-center gap-4 my-2 md:my-4 text-sm">
      <span>{{ 'generic.tags' | t }}：</span>
      {% for tag in page.settings.tags %}
      <a href="{{ tag.path }}" data-turbo-frame="_top"
        class="inline-flex items-center transition-all duration-200 hover:-translate-y-[2px]">
        {% render 'tag', tag: tag %}
      </a>
      {% endfor %}
    </div>
  {% endif %}

  {% # feedback %}
  <!-- 用官方的 ID.showModal() method 会出现z-index覆盖的错误（https://github.com/saadeghi/daisyui/issues/2858）# -->
  <!-- 所以以下代码增加了 Alpinejs 的 open变量控制窗口的显示与否 -->
  <div x-data="{ open: false }" class="flex flex-col items-center justify-center w-full my-8 space-y-3 print:hidden" id="{{ page.id }}_feedback">
    <a data-turbo-method="get" data-turbo-stream="true" x-on:click="open = ! open" href="{{site.index_path}}-/feedbacks/new?page_path={{ page.path }}"
      class="flex items-center justify-center border-2 rounded-full cursor-pointer w-14 h-14 btn"
      :class="{ 'bg-primary text-white': {{ page.visitor_posted_feedback }} }">
      <svg t="1698223767490" class="w-6 h-6 icon" viewBox="0 0 1024 1024" version="1.1"
        xmlns="http://www.w3.org/2000/svg" p-id="4875">
        <path
          d="M1000.59 407.182c-26.679-43.859-67.358-67.449-120.938-70.119-3.23-0.38-6.32-0.57-9.32-0.57l-172.356-0.59c7.819-34.839 11.979-70.079 11.979-102.798 0-33.489-3.66-67.259-10.89-100.388a41.025 41.025 0 0 0-2.36-7.35c-18.68-68.139-79.099-115.118-149.337-115.118-83.269 0-146.058 68.279-146.058 158.817l-0.061 2.28c-0.08 2.39-0.17 5.46 0.01 9.02-3.569 94.348-81.148 176.707-177.807 188.767l-136.178 2.19c-2.24-0.2-4.48-0.3-6.72-0.3-44.209 0-80.178 36.369-80.178 81.039l-0.37 481.182c0 44.369 35.989 80.479 80.229 80.479l149.368 0.03h0.08l567.93-0.98h0.011c31.429 0 51.139-8.8 74.589-24.02a158.319 158.319 0 0 0 54.589-60.578c4.33-6.98 7.55-14.44 9.59-22.22 0.13-0.511 0.26-1.021 0.37-1.521l84.648-381.714a81.977 81.977 0 0 0 2.33-22.699c1.82-32.89-6.16-64.939-23.15-92.839zM82.305 453.161c1.24 0.1 2.49 0.14 3.73 0.12l98.918-1.6v480.142l-103.028-0.02 0.38-478.642z m859.257 51.259l-84.419 380.673h-0.02a39.79 39.79 0 0 0-2.71 4.7c-6.15 12.5-15.2 22.699-26.84 30.27-14.989 9.729-19.319 10.79-30.369 10.79h-0.011l-530.321 0.915V444.231c122.238-30.1 212.877-137.708 216.337-263.466 0.05-1.68 0.03-2.8-0.13-4.48-0.021-0.78 0.02-1.56 0.05-2.35 0.05-1.61 0.09-3.23 0.09-4.87 0-38.22 22.04-76.899 64.149-76.899 34.129 0 63.408 24.02 71.208 58.399 0.44 1.92 1.011 3.78 1.7 5.57 5.15 25.48 7.76 51.339 7.76 76.969 0 40.479-8.31 87.989-22.789 130.318a40.914 40.914 0 0 0 5.39 37.02 40.906 40.906 0 0 0 33.22 17.2l226.506 0.81c1.36 0.19 2.72 0.31 4.09 0.37 26.83 1.1 43.63 10.34 56.159 30.949 8.561 14.06 12.45 30.35 11.25 47.109-0.15 2.02-0.12 4.12 0.04 6.14-0.121 0.47-0.241 0.93-0.34 1.4z"
          fill="currentColor" p-id="4876"></path>
      </svg>
    </a>
    <div class="w-full text-center">{{ 'feedback.title' | t}}</div>

    <dialog id="my_modal_feedback" class="modal" :class="{ 'modal-open' : open }">
      <div class="modal-box">
        {% render "feedback_form", page: page %}
      </div>
      <form method="dialog" class="modal-backdrop" x-on:click="open = false">
        <button>Close</button>
      </form>
    </dialog>
  </div>

  <!-- 上下页 -->
  <div class="divider"></div>
  <div class="md:flex gap-7 space-y-4 md:space-y-0">
    {% if page.prev_page %}
      <a class="mr-auto flex" href="{{ page.prev_page.path }}" data-turbo-action="replace">
        <button class="btn rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24">
            <path fill="currentColor"
              d="M16.707 19.293 9.414 12l7.293-7.293-1.414-1.414L6.586 12l8.707 8.707 1.414-1.414z"></path>
          </svg>
          <span class="text-xs md:text-sm font-medium">{{ page.prev_page.link_text | truncate: 42 }}</span>
        </button>
      </a>
    {% endif %}
    {% if page.next_page %}
      <a class="ml-auto flex" href="{{ page.next_page.path }}" data-turbo-action="replace">
        <button class="btn rounded-full">
          <span class="text-xs md:text-sm font-medium">{{ page.next_page.link_text | truncate: 42}}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24">
            <path fill="currentColor"
              d="M7.293 4.707 14.586 12l-7.293 7.293 1.414 1.414L17.414 12 8.707 3.293 7.293 4.707z"></path>
          </svg>
        </button>
      </a>
    {% endif %}
  </div>

  {% # 页内目录导航 %}

</section>
